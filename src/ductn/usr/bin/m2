#!/bin/bash
# m2 — Magento 2 CLI wrapper
# Routes all commands through ductn php:m2
#
# Usage:
#   m2                  — Show all available Magento 2 actions
#   m2 <action>         — Run an action (cache, static, rmgen, ...)
#   m2 <magento cmd>    — Forward directly to bin/magento

exec ductn php:m2 "$@"
