#!/usr/bin/env bash
set -euo pipefail

# ductncli - launch Hermes/Codex in tmux for a workspace directory.
# Usage:
#   /root/scripts/ductncli hermes ~/projects/portal
#   /root/scripts/ductncli codex projects/portal
#   /root/scripts/ductncli ~/projects/portal       # default agent: hermes
#   /root/scripts/ductncli                         # select agent, workspace defaults to ~/

CODEX_PROFILE_NAME="ninerouter"
DEFAULT_WORKSPACE_DIR="$HOME"
OPENCLAW_PROJECT_DIR="$HOME/.openclaw/workspace/projects"
HERMES_PROJECT_DIR="$HOME/.hermes/workspace/projects"

usage() {
    cat <<'EOF'
Usage:
  ductncli [hermes|codex] [path]
  ductncli [path]                 # defaults to hermes
  ductncli                        # select agent, workspace defaults to ~/

Examples:
  ductncli hermes
  ductncli codex
  ductncli hermes ~/projects/portal
  ductncli codex projects/portal
  ductncli ductnd
  ductncli /root/.hermes/workspace/projects/ductnd

Workspace path resolution:
  - No path: use ~/
  - Absolute path: use it if the directory exists
  - Relative path: try ./path first, then ~/path
  - Project shortcut: try ~/.openclaw/workspace/projects/path, then ~/.hermes/workspace/projects/path
EOF
}

die() {
    echo "ERROR: $*" >&2
    exit 1
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

select_agent() {
    local choice

    echo "Select an agent:" >&2
    echo "----------------------------------------" >&2
    echo "1) hermes [default]" >&2
    echo "2) codex" >&2
    echo "0) Exit" >&2
    echo "" >&2

    read -r -p "Enter your choice [1]: " choice
    choice="${choice:-1}"

    case "$choice" in
        1|h|H|hermes) printf '%s\n' "hermes" ;;
        2|c|C|codex) printf '%s\n' "codex" ;;
        0|q|Q|exit) echo "Exited." >&2; exit 0 ;;
        *) die "Invalid agent choice." ;;
    esac
}

expand_tilde_path() {
    local input="$1"

    case "$input" in
        "~") printf '%s\n' "$HOME" ;;
        "~/"*) printf '%s/%s\n' "$HOME" "${input#~/}" ;;
        *) printf '%s\n' "$input" ;;
    esac
}

resolve_workspace_dir() {
    local input="${1:-}"
    local expanded relative_home openclaw_project hermes_project

    if [ -z "$input" ]; then
        printf '%s\n' "$DEFAULT_WORKSPACE_DIR"
        return 0
    fi

    expanded="$(expand_tilde_path "$input")"

    # 1) Direct path: absolute, explicit relative, or ~/path.
    if [ -d "$expanded" ]; then
        realpath "$expanded"
        return 0
    fi

    # 2) Relative path under ~/.
    if [[ "$expanded" != /* ]]; then
        relative_home="$HOME/$expanded"
        if [ -d "$relative_home" ]; then
            realpath "$relative_home"
            return 0
        fi

        # 3) Legacy project shortcut: project name -> openclaw/project first, then hermes/project.
        openclaw_project="$OPENCLAW_PROJECT_DIR/$expanded"
        if [ -d "$openclaw_project" ]; then
            realpath "$openclaw_project"
            return 0
        fi

        hermes_project="$HERMES_PROJECT_DIR/$expanded"
        if [ -d "$hermes_project" ]; then
            realpath "$hermes_project"
            return 0
        fi
    fi

    die "Workspace directory not found: $input (checked: $expanded${relative_home:+, $relative_home}${openclaw_project:+, $openclaw_project}${hermes_project:+, $hermes_project})"
}

workspace_session_slug() {
    local path="$1"
    local slug

    if [ "$path" = "$HOME" ]; then
        printf '%s\n' "home"
        return 0
    fi

    slug="${path#$HOME/}"
    slug="${slug#/}"
    slug="${slug//\//-}"
    slug="${slug//[^[:alnum:]_-]/_}"
    slug="${slug:-workspace}"
    printf '%s\n' "$slug"
}

ensure_shell_pane() {
    local session_name="$1"
    local workspace_dir="$2"
    local pane_count

    pane_count="$(tmux list-panes -t "$session_name" 2>/dev/null | wc -l | tr -d ' ')"

    if [ "$pane_count" -lt 2 ]; then
        echo "Creating right bash pane in: $workspace_dir"
        tmux split-window -h -t "$session_name:0.0" -c "$workspace_dir" bash
        tmux select-pane -t "$session_name:0.0"
        tmux select-layout -t "$session_name" even-horizontal >/dev/null 2>&1 || true
    fi
}

attach_existing_session() {
    local session_name="$1"
    local alt_session_name="$2"
    local workspace_dir="$3"

    if tmux has-session -t "$session_name" 2>/dev/null; then
        ensure_shell_pane "$session_name" "$workspace_dir"
        echo "Session $session_name already exists. Attaching..."
        tmux attach -t "$session_name"
        exit 0
    fi

    if [ -n "$alt_session_name" ] && tmux has-session -t "$alt_session_name" 2>/dev/null; then
        ensure_shell_pane "$alt_session_name" "$workspace_dir"
        echo "Session $alt_session_name already exists. Attaching..."
        tmux attach -t "$alt_session_name"
        exit 0
    fi
}

confirm_start() {
    local agent="$1"
    local workspace_dir="$2"
    local confirm

    read -r -p "Start $agent in '$workspace_dir'? (Y/n): " confirm
    confirm="${confirm:-Y}"
    [[ "$confirm" =~ ^[Yy]$ ]] || {
        echo "Cancelled."
        exit 0
    }
}

start_agent() {
    local agent="$1"
    local workspace_dir="$2"
    local session_name alt_session_name quoted_workspace_dir command_text slug

    [ -d "$workspace_dir" ] || die "Workspace directory not found: $workspace_dir"

    slug="$(workspace_session_slug "$workspace_dir")"
    session_name="${agent}-${slug}"
    alt_session_name="${session_name//./_}"

    attach_existing_session "$session_name" "$alt_session_name" "$workspace_dir"

    case "$agent" in
        hermes)
            command_text="hermes"
            ;;
        codex)
            command_text="codex --profile $CODEX_PROFILE_NAME"
            ;;
        *)
            die "Invalid agent: $agent"
            ;;
    esac

    printf -v quoted_workspace_dir '%q' "$workspace_dir"

    echo "Starting $agent"
    echo "Workspace: $workspace_dir"
    [ "$agent" = "codex" ] && echo "Codex profile: $CODEX_PROFILE_NAME"
    echo "Session: $session_name"

    tmux new-session -d -s "$session_name" -c "$workspace_dir"
    tmux send-keys -t "$session_name:0.0" "cd $quoted_workspace_dir" C-m
    tmux send-keys -t "$session_name:0.0" "$command_text" C-m
    ensure_shell_pane "$session_name" "$workspace_dir"

    echo "Session created. Left pane: $agent. Right pane: bash. Attaching in 2 seconds..."
    sleep 2
    tmux attach -t "$session_name"
}

main() {
    local agent=""
    local path_input=""
    local first="${1:-}"
    local second="${2:-}"
    local workspace_dir

    case "$first" in
        -h|--help|help)
            usage
            exit 0
            ;;
        hermes|codex)
            agent="$first"
            path_input="$second"
            if [ -n "${3:-}" ]; then
                die "Too many arguments. Use: ductncli [hermes|codex] [path]"
            fi
            ;;
        "")
            agent="$(select_agent)"
            ;;
        *)
            agent="hermes"
            path_input="$first"
            if [ -n "$second" ]; then
                die "Too many arguments. Use: ductncli [hermes|codex] [path]"
            fi
            ;;
    esac

    require_cmd tmux
    require_cmd "$agent"
    require_cmd realpath

    workspace_dir="$(resolve_workspace_dir "$path_input")"
    confirm_start "$agent" "$workspace_dir"
    start_agent "$agent" "$workspace_dir"
}

main "$@"
