#!/usr/bin/env bash
#!/bin/bash
#!/bin/sh
# postinst script
#
# see: dh_installdeb(1)

set -e

ductn_locale_works() {
    local candidate="$1"
    LC_ALL="$candidate" locale charmap >/dev/null 2>&1
}

setup_ductn_locale() {
    # Prefer C.UTF-8 because it is available by default on modern Debian/Ubuntu
    # systems and does not require locale generation. Fall back to en_US.UTF-8
    # when C.UTF-8 is not usable.
    local preferred_locale="C.UTF-8"
    local fallback_locale="en_US.UTF-8"
    local selected_locale=""

    if ductn_locale_works "$preferred_locale"; then
        selected_locale="$preferred_locale"
    elif ductn_locale_works "$fallback_locale"; then
        selected_locale="$fallback_locale"
    else
        if command -v locale-gen >/dev/null 2>&1; then
            if [[ -f /etc/locale.gen ]] && ! grep -Eq '^[[:space:]]*en_US.UTF-8[[:space:]]+UTF-8' /etc/locale.gen; then
                if grep -Eq '^[[:space:]]*#[[:space:]]*en_US.UTF-8[[:space:]]+UTF-8' /etc/locale.gen; then
                    sed -i 's/^[[:space:]]*#[[:space:]]*\(en_US.UTF-8[[:space:]]\+UTF-8\)/\1/' /etc/locale.gen || true
                else
                    printf '%s\n' 'en_US.UTF-8 UTF-8' >>/etc/locale.gen || true
                fi
            fi
            locale-gen en_US.UTF-8 >/dev/null 2>&1 || true
        fi

        if ductn_locale_works "$fallback_locale"; then
            selected_locale="$fallback_locale"
        else
            selected_locale="$preferred_locale"
        fi
    fi

    export LANG="$selected_locale"
    export LC_ALL="$selected_locale"
    export LANGUAGE="en_US:en"

    if command -v update-locale >/dev/null 2>&1; then
        update-locale LANG="$selected_locale" LC_ALL="$selected_locale" LANGUAGE="en_US:en" >/dev/null 2>&1 || true
    fi

    echo "[ductn] ✔ Locale configured: $selected_locale"
}

# summary of how this script can be called:
#        * <postinst> `configure' <most-recently-configured-version>
#        * <old-postinst> `abort-upgrade' <new version>
#        * <conflictor's-postinst> `abort-remove' `in-favour' <package>
#          <new-version>
#        * <postinst> `abort-remove'
#        * <deconfigured's-postinst> `abort-deconfigure' `in-favour'
#          <failed-install-package> <version> `removing'
#          <conflicting-package> <version>
# for details, see http://www.debian.org/doc/debian-policy/ or
# the debian-policy package

case "$1" in
configure)
    setup_ductn_locale

    if command -v ductn >/dev/null 2>&1; then
        ductn time:timezone >/dev/null 2>&1 || true
        ductn sys:sysctl >/dev/null 2>&1 || true
    fi

    systemctl daemon-reload
    systemctl enable ductnd.service >/dev/null 2>&1 || true
    systemctl restart ductnd.service >/dev/null 2>&1 || true

    CONFIG_FILE="/etc/lxc/default.conf"
    HOOK_LINE="lxc.hook.create = /var/lib/lxc/hooks/default-hook.sh"

    # Kiểm tra file có tồn tại không
    if [[ -f "$CONFIG_FILE" ]]; then
        # Kiểm tra xem dòng hook đã có trong file chưa
        if grep -Fxq "$HOOK_LINE" "$CONFIG_FILE"; then
            echo "[ductn] ✔ Hook đã tồn tại trong $CONFIG_FILE"
        else
            echo "$HOOK_LINE" | sudo tee -a "$CONFIG_FILE" >/dev/null
            echo "[ductn] ✔ Đã thêm hook vào $CONFIG_FILE"
        fi
    fi

    MOTD_FILE="/etc/update-motd.d/99-ductn"

    if [[ -f "$MOTD_FILE" ]]; then
        chmod +x "$MOTD_FILE"
        echo "[ductn] ✔ MOTD script permissions set."
    fi

    DUCTNCLI_FILE="/usr/bin/ductncli"
    if [[ -f "$DUCTNCLI_FILE" ]]; then
        chmod +x "$DUCTNCLI_FILE"
        echo "[ductn] ✔ ductncli permissions set."
    fi

    TMUX_SOURCE="/etc/ductn/tmux.conf"
    TMUX_TARGET="/root/.tmux.conf"
    if [[ -f "$TMUX_SOURCE" ]]; then
        cp "$TMUX_SOURCE" "$TMUX_TARGET"
        echo "[ductn] ✔ tmux config installed to $TMUX_TARGET"
    fi

    # Setup shpool user service
    INSTALL_USER="${SUDO_USER:-$USER}"
    if [[ -n "$INSTALL_USER" && "$INSTALL_USER" != "root" ]]; then
        echo "[ductn] Configuring shpool for user: $INSTALL_USER"
        loginctl enable-linger "$INSTALL_USER" 2>/dev/null || true
        sudo -u "$INSTALL_USER" systemctl --user daemon-reload 2>/dev/null || true
        sudo -u "$INSTALL_USER" systemctl --user enable shpool.service 2>/dev/null || true
        sudo -u "$INSTALL_USER" systemctl --user start shpool.service 2>/dev/null || true
        echo "[ductn] ✔ shpool user service enabled for $INSTALL_USER"
    else
        echo "[ductn] ⚠ Cannot determine installing user. Run manually:"
        echo "    loginctl enable-linger"
        echo "    systemctl --user enable --now shpool"
    fi
    ;;

abort-upgrade | abort-remove | abort-deconfigure) ;;

*)
    echo "[ductn] postinst called with unknown argument \`$1'" >&2
    exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
